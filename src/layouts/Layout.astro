---
import { SEO } from "astro-seo";
import Footer from "@/components/footer.astro";
import Navbar from "@/components/navbar/navbar.astro";
import "@fontsource-variable/bricolage-grotesque/index.css";
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const resolvedImageWithDomain = new URL("/opengraph.jpg", Astro.site).toString();

const {
  title = "",
  description = "EduMyna is a nonprofit education initiative working in the gap between school and the world — funding programs, building tools, and shaping the discourse around India's undergraduate years.",
} = Astro.props;

const makeTitle = title
  ? `${title} | EduMyna`
  : "EduMyna | Education Initiative";
---

<!doctype html>
<html lang="en" class="bg-myna-black">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <SEO
      title={makeTitle}
      description={description}
      canonical={canonicalURL}
      twitter={{ card: "summary_large_image" }}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: "website",
          title: makeTitle,
          image: resolvedImageWithDomain,
        },
        image: { alt: "EduMyna" },
      }}
    />
  </head>
  <body class="bg-myna-black text-myna-white min-h-screen">
    <Navbar />
    <slot />
    <Footer />
  </body>
</html>

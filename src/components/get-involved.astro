---
const paths = [
  {
    number: "I",
    title: "Build with us",
    description:
      "If you believe that what happens in the undergraduate years matters, and you want to spend your time on something that actually moves the needle — let's talk.",
    cta: "Talk to us",
    href: "/contact",
  },
  {
    number: "II",
    title: "Partner with us",
    description:
      "Universities, governments, community organizations, nonprofits, private educational institutions. EduMyna works best embedded in existing ecosystems. If your mission and ours overlap, let's find out how.",
    cta: "Explore partnership",
    href: "/contact",
  },
  {
    number: "III",
    title: "Fund the mission",
    description:
      "EduMyna is registering as a Section 8 nonprofit. We are looking for early believers — people and institutions who understand that fixing higher education in India is among the most consequential and necessary things we can get right.",
    cta: "Discuss funding",
    href: "/contact",
  },
];
---

<section class="bg-myna-black border-t border-myna-brown/30">
  <div class="max-w-7xl mx-auto px-5 sm:px-8 py-20 lg:py-28">

    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-8 mb-16">
      <div>
        <div class="inline-flex items-center gap-2 mb-4">
          <span class="h-px w-8 bg-myna-amber"></span>
          <span class="text-xs font-bold uppercase tracking-widest text-myna-amber">
            Get involved
          </span>
        </div>
        <h2 class="text-4xl lg:text-5xl font-bold text-myna-white tracking-tight leading-tight">
          Three ways to be<br />part of this.
        </h2>
      </div>
      <p class="text-sm text-myna-white/40 max-w-sm leading-relaxed lg:text-right">
        EduMyna is early. That means the people who show up now
        will shape what it becomes.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-px bg-myna-brown/20">
      {paths.map((p) => (
        <div class="bg-myna-black p-8 lg:p-10 flex flex-col hover:bg-myna-brown/10 transition-colors duration-200">
          <span class="text-5xl font-bold text-myna-brown/30 tracking-tight leading-none mb-8">
            {p.number}
          </span>
          <h3 class="text-xl font-bold text-myna-white tracking-tight mb-4">
            {p.title}
          </h3>
          <p class="text-sm text-myna-white/50 leading-relaxed flex-1">
            {p.description}
          </p>
          <a
            href={p.href}
            class="mt-8 inline-flex items-center gap-1 text-sm font-bold uppercase tracking-widest text-myna-amber hover:text-myna-white transition-colors">
            {p.cta} →
          </a>
        </div>
      ))}
    </div>

  </div>
</section>

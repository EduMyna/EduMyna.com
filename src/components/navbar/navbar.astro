---
import { Astronav, MenuItems, MenuIcon } from "astro-navbar";

const menuitems = [
  { title: "Mission", path: "/about" },
  { title: "Programs", path: "/story" },
  { title: "Resources", path: "/resources" },
  { title: "Blog", path: "/blog" },
];
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-myna-brown/30 bg-myna-black/90 backdrop-blur-sm">
  <div class="max-w-7xl mx-auto px-5 sm:px-8">
    <div class="flex items-center justify-between h-16 lg:h-18">

      <Astronav>
        <div class="flex w-full lg:w-auto items-center justify-between">
          <!-- Logo -->
          <a href="/" class="flex items-center gap-1 shrink-0">
            <span class="text-xl font-bold tracking-tight text-myna-white">
              Edu<span class="text-myna-amber">Myna</span>
            </span>
          </a>

          <!-- Mobile hamburger -->
          <div class="block lg:hidden ml-4">
            <MenuIcon class="w-6 h-6 text-myna-white" />
          </div>
        </div>

        <!-- Nav links -->
        <MenuItems class="hidden w-full lg:w-auto mt-4 lg:flex lg:mt-0 lg:items-center">
          <ul class="flex flex-col gap-1 pb-4 lg:pb-0 lg:flex-row lg:gap-0 lg:items-center">
            {menuitems.map((item) => (
              <li>
                <a
                  href={item.path}
                  class="flex px-4 py-2 text-sm font-medium text-myna-white/60 hover:text-myna-amber transition-colors duration-200 tracking-wide uppercase">
                  {item.title}
                </a>
              </li>
            ))}
            <!-- Mobile CTA -->
            <li class="block lg:hidden mt-2 px-4">
              <a
                href="/contact"
                class="inline-flex w-full items-center justify-center rounded-sm bg-myna-amber px-5 py-2.5 text-sm font-bold text-myna-black hover:bg-myna-amber-dark transition-colors tracking-wide uppercase">
                Get Involved
              </a>
            </li>
          </ul>
        </MenuItems>
      </Astronav>

      <!-- Desktop CTA -->
      <div class="hidden lg:flex items-center">
        <a
          href="/contact"
          class="inline-flex items-center justify-center rounded-sm bg-myna-amber px-5 py-2.5 text-sm font-bold text-myna-black hover:bg-myna-amber-dark transition-colors duration-200 tracking-wide uppercase">
          Get Involved
        </a>
      </div>

    </div>
  </div>
</header>

<!-- Spacer to offset fixed nav -->
<div class="h-16 lg:h-18"></div>

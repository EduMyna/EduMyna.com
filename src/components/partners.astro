---
const partners = [
  {
    name: "TinkerHub Foundation",
    description: "Our ground-level partner running cohort programs with college students across Kerala.",
    type: "Program Partner",
  },
  {
    name: "FOSS United",
    description: "Supporting the open-source education stack and community-driven learning infrastructure.",
    type: "Community Partner",
  },
  {
    name: "The Second Design",
    description: "The operational entity running on-ground programs under the EduMyna umbrella.",
    type: "Operating Arm",
  },
];
---

<section class="bg-myna-cream">
  <div class="max-w-7xl mx-auto px-5 sm:px-8 py-20">

    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-14">
      <div>
        <div class="inline-flex items-center gap-2 mb-4">
          <span class="h-px w-8 bg-myna-brown"></span>
          <span class="text-xs font-bold uppercase tracking-widest text-myna-brown">
            Who we work with
          </span>
        </div>
        <h2 class="text-4xl lg:text-5xl font-bold text-myna-black tracking-tight">
          Our partners.
        </h2>
      </div>
      <p class="text-sm text-myna-black/50 max-w-sm leading-relaxed">
        EduMyna works with mission-aligned nonprofits and community organizations to run programs on the ground.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {partners.map((p) => (
        <div class="bg-white border border-myna-brown/15 rounded-sm p-8">
          <span class="text-xs font-bold uppercase tracking-widest text-myna-amber">
            {p.type}
          </span>
          <h3 class="mt-3 text-lg font-bold text-myna-black tracking-tight">
            {p.name}
          </h3>
          <p class="mt-2 text-sm text-myna-black/60 leading-relaxed">
            {p.description}
          </p>
        </div>
      ))}
    </div>

  </div>
</section>

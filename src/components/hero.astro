---
---

<section class="relative overflow-hidden bg-myna-black">

  <!-- Background gradient — dark warm to brown -->
  <div class="absolute inset-0 bg-gradient-to-br from-myna-black via-myna-black to-myna-brown/40 pointer-events-none"></div>

  <!-- Decorative large faded "EM" -->
  <div class="absolute right-0 top-1/2 -translate-y-1/2 text-[20rem] font-bold text-myna-brown/10 leading-none select-none pointer-events-none tracking-tighter pr-8 hidden lg:block">
    EM
  </div>

  <!-- Subtle dot pattern -->
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none"
    style="background-image: radial-gradient(circle, #F5EFE0 1px, transparent 1px); background-size: 32px 32px;">
  </div>

  <div class="relative max-w-7xl mx-auto px-5 sm:px-8 pt-20 pb-24 lg:pt-28 lg:pb-32">

    <!-- Eyebrow -->
    <div class="inline-flex items-center gap-2 mb-8">
      <span class="h-px w-8 bg-myna-amber"></span>
      <span class="text-xs font-bold uppercase tracking-widest text-myna-amber">
        Education Initiative · India
      </span>
    </div>

    <!-- Headline -->
    <h1 class="text-5xl sm:text-6xl lg:text-7xl xl:text-8xl font-bold leading-[1.05] tracking-tight text-myna-white max-w-4xl">
      Nation builders<br />
      are made,<br />
      <span class="text-myna-amber">not born.</span>
    </h1>

    <!-- Sub -->
    <p class="mt-8 text-lg sm:text-xl text-myna-white/60 max-w-2xl leading-relaxed">
      EduMyna works in the gap between leaving school and entering the world.
      We fund programs, build tools, and shape the discourse around what
      India's undergraduate years should mean.
    </p>

    <!-- CTAs -->
    <div class="mt-10 flex flex-col sm:flex-row gap-4">
      <a
        href="/story"
        class="inline-flex items-center justify-center rounded-sm bg-myna-amber px-7 py-3.5 text-sm font-bold text-myna-black hover:bg-myna-amber-dark transition-colors tracking-wide uppercase">
        See our programs
      </a>
      <a
        href="/contact"
        class="inline-flex items-center justify-center rounded-sm border border-myna-white/20 px-7 py-3.5 text-sm font-bold text-myna-white hover:border-myna-amber hover:text-myna-amber transition-colors tracking-wide uppercase">
        Get involved
      </a>
    </div>

    <!-- Running since -->
    <p class="mt-10 text-xs text-myna-white/30 uppercase tracking-widest">
      Running education programs since 2013
    </p>

  </div>
</section>

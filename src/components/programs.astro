---
const areas = [
  {
    number: "01",
    title: "Fund & Enable Programs",
    description:
      "EduMyna provides funding and institutional support for education programs operating in India's higher education space — the post-12th to graduation years that the formal system underleverages.",
    href: "/story",
    bg: "bg-myna-black",
    headerBg: "bg-myna-brown",
    textColor: "text-myna-white",
    mutedColor: "text-myna-white/55",
    accentColor: "text-myna-amber",
    icon: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-10 h-10">
      <circle cx="24" cy="24" r="20" stroke="#F5A623" stroke-width="2"/>
      <path d="M16 24h16M24 16v16" stroke="#F5A623" stroke-width="2.5" stroke-linecap="round"/>
    </svg>`,
  },
  {
    number: "02",
    title: "Build Open Software",
    description:
      "We build and maintain open-source tools for the realities of running education programs in India — an LMS and a growing suite of micro tools. Self-hostable, no vendor lock-in, designed by people who have actually run programs at scale.",
    href: "/blog",
    bg: "bg-myna-cream",
    headerBg: "bg-myna-amber",
    textColor: "text-myna-black",
    mutedColor: "text-myna-black/55",
    accentColor: "text-myna-brown",
    icon: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-10 h-10">
      <rect x="8" y="12" width="32" height="24" rx="3" stroke="#1A1209" stroke-width="2"/>
      <path d="M17 20l-4 4 4 4M31 20l4 4-4 4M23 18l2 12" stroke="#1A1209" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>`,
  },
  {
    number: "03",
    title: "Shape the Discourse",
    description:
      "The art and science of pedagogy. Impact measurement. Cohort-based courses. The role of LLMs in education. Policy initiatives. EduMyna publishes, advocates, and builds the intellectual case for a different kind of education in India.",
    href: "/resources",
    bg: "bg-myna-brown",
    headerBg: "bg-myna-black",
    textColor: "text-myna-white",
    mutedColor: "text-myna-white/55",
    accentColor: "text-myna-amber",
    icon: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-10 h-10">
      <path d="M12 36V14a2 2 0 012-2h20a2 2 0 012 2v22" stroke="#F5A623" stroke-width="2"/>
      <path d="M8 36h32M20 20h8M20 26h8M20 32h4" stroke="#F5A623" stroke-width="2" stroke-linecap="round"/>
    </svg>`,
  },
];
---

<section class="bg-myna-cream">
  <div class="max-w-7xl mx-auto px-5 sm:px-8 pt-20 pb-8 lg:pt-28 lg:pb-10">

    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-14">
      <div>
        <div class="inline-flex items-center gap-2 mb-4">
          <span class="h-px w-8 bg-myna-brown"></span>
          <span class="text-xs font-bold uppercase tracking-widest text-myna-brown">
            What EduMyna does
          </span>
        </div>
        <h2 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-myna-black tracking-tight leading-tight">
          Three things.<br />Done well.
        </h2>
      </div>
      <p class="text-sm text-myna-black/45 max-w-xs leading-relaxed lg:text-right pb-2">
        Every initiative EduMyna runs falls under one of these three areas.
      </p>
    </div>

  </div>

  <!-- Full-bleed card grid -->
  <div class="grid md:grid-cols-3">
    {areas.map((a) => (
      <a href={a.href} class:list={["group flex flex-col", a.bg]}>

        <!-- Card header with icon -->
        <div class:list={["px-8 lg:px-10 pt-10 pb-8 relative overflow-hidden", a.headerBg]}>
          <!-- Large faded number -->
          <span class="absolute top-2 right-4 text-8xl font-bold opacity-10 leading-none tracking-tighter text-current select-none">
            {a.number}
          </span>
          <div set:html={a.icon} />
        </div>

        <!-- Card body -->
        <div class="px-8 lg:px-10 py-8 flex flex-col flex-1">
          <div class:list={["text-xs font-bold uppercase tracking-widest mb-3 opacity-50", a.textColor]}>
            {a.number}
          </div>
          <h3 class:list={["text-2xl font-bold tracking-tight mb-4", a.textColor]}>
            {a.title}
          </h3>
          <p class:list={["text-sm leading-relaxed flex-1", a.mutedColor]}>
            {a.description}
          </p>
          <span class:list={[
            "mt-8 text-xs font-bold uppercase tracking-widest group-hover:underline transition-all",
            a.accentColor,
          ]}>
            Read more →
          </span>
        </div>

      </a>
    ))}
  </div>

</section>

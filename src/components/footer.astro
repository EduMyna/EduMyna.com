---
const year = new Date().getFullYear();
const EMAIL = "gautham@edumyna.com";

const links = {
  initiative: [
    { label: "Mission", href: "/about" },
    { label: "Programs", href: "/story" },
    { label: "Story", href: "/story" },
    { label: "Press", href: "/press-mentions" },
  ],
  learn: [
    { label: "Resources", href: "/resources" },
    { label: "Blog", href: "/blog" },
    { label: "Cohort-Based Courses", href: "/resources/cohort-based-courses" },
  ],
  connect: [
    { label: "Get Involved", href: "/contact" },
    { label: "Contact", href: "/contact" },
    { label: EMAIL, href: `mailto:${EMAIL}` },
  ],
};
---

<footer class="bg-myna-black border-t border-myna-brown/30">
  <div class="max-w-7xl mx-auto px-5 sm:px-8 py-16">

    <div class="grid md:grid-cols-4 gap-12">
      <!-- Brand -->
      <div class="md:col-span-1">
        <a href="/" class="inline-flex">
          <span class="text-2xl font-bold tracking-tight text-myna-white">
            Edu<span class="text-myna-amber">Myna</span>
          </span>
        </a>
        <p class="mt-4 text-sm text-myna-white/50 leading-relaxed max-w-xs">
          Working in the gap between school and the world — for India's undergraduate years.
        </p>
        <p class="mt-4 text-xs text-myna-white/30 uppercase tracking-widest">
          Section 8 Company · India
        </p>
      </div>

      <!-- Initiative -->
      <div>
        <h4 class="text-xs font-bold uppercase tracking-widest text-myna-amber mb-4">
          Initiative
        </h4>
        <ul class="space-y-3">
          {links.initiative.map((l) => (
            <li>
              <a href={l.href} class="text-sm text-myna-white/60 hover:text-myna-white transition-colors">
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Learn -->
      <div>
        <h4 class="text-xs font-bold uppercase tracking-widest text-myna-amber mb-4">
          Learn
        </h4>
        <ul class="space-y-3">
          {links.learn.map((l) => (
            <li>
              <a href={l.href} class="text-sm text-myna-white/60 hover:text-myna-white transition-colors">
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Connect -->
      <div>
        <h4 class="text-xs font-bold uppercase tracking-widest text-myna-amber mb-4">
          Connect
        </h4>
        <ul class="space-y-3">
          {links.connect.map((l) => (
            <li>
              <a href={l.href} class="text-sm text-myna-white/60 hover:text-myna-white transition-colors break-all">
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-16 pt-8 border-t border-myna-brown/20 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <p class="text-xs text-myna-white/30">
        © {year} EduMyna. All rights reserved.
      </p>
      <p class="text-xs text-myna-white/30 italic">
        Nation builders are made, not born.
      </p>
    </div>

  </div>
</footer>

---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
---

<Layout
  title="Resources"
  description="Guides, frameworks, and insights on building transformative learning programs"
>
  <Container>
    <div class="max-w-5xl mx-auto py-16 md:py-24">
      <!-- Hero -->
      <div class="mb-16 text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-slate-900 mb-4">Resources</h1>
        <p class="text-xl text-slate-600 max-w-3xl mx-auto">
          Guides, frameworks, and insights on building transformative learning programs—drawn from 12 years of running real education programs.
        </p>
      </div>

      <!-- Resources Grid -->
      <div class="grid gap-8">

        <!-- Cohort-Based Courses -->
        <article class="group bg-white border-2 border-slate-200 rounded-2xl p-8 hover:border-blue-300 hover:shadow-lg transition-all">
          <div class="flex items-start gap-6">
            <div class="w-16 h-16 bg-blue-100 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-blue-200 transition-colors">
              <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
              </svg>
            </div>
            <div class="flex-1">
              <h2 class="text-2xl font-bold text-slate-900 mb-2 group-hover:text-blue-600 transition-colors">
                <a href="/resources/cohort-based-courses" class="block">
                  Cohort-Based Courses: A Complete Guide
                </a>
              </h2>
              <p class="text-slate-600 mb-4">
                Everything you need to know about cohort-based courses—what they are, how they're better than MOOCs and universities, how to build them, and what the future holds.
              </p>
              <div class="flex flex-wrap gap-2 mb-4">
                <span class="px-3 py-1 bg-slate-100 text-slate-700 text-xs font-medium rounded-full">Active Learning</span>
                <span class="px-3 py-1 bg-slate-100 text-slate-700 text-xs font-medium rounded-full">80-90% Completion</span>
                <span class="px-3 py-1 bg-slate-100 text-slate-700 text-xs font-medium rounded-full">Community-Driven</span>
              </div>
              <a href="/resources/cohort-based-courses" class="text-blue-600 hover:text-blue-700 font-semibold inline-flex items-center gap-2">
                Read guide
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </div>
        </article>

        <!-- More resources coming soon placeholder -->
        <div class="bg-slate-50 border-2 border-dashed border-slate-300 rounded-2xl p-8 text-center">
          <div class="w-12 h-12 bg-slate-200 rounded-lg mx-auto mb-4 flex items-center justify-center">
            <svg class="w-6 h-6 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
          </div>
          <p class="text-slate-500 font-medium">More resources coming soon</p>
          <p class="text-sm text-slate-400 mt-2">Guides on pedagogy, course design, feedback systems, and more</p>
        </div>

      </div>

      <!-- Related Links -->
      <div class="mt-16 pt-12 border-t border-slate-200">
        <h2 class="text-xl font-bold text-slate-900 mb-6">Explore More</h2>
        <div class="grid md:grid-cols-3 gap-4">
          <a href="/story" class="block p-4 bg-white border border-slate-200 rounded-lg hover:border-blue-300 hover:shadow transition-all">
            <p class="font-semibold text-slate-900 mb-1">Our Story</p>
            <p class="text-sm text-slate-600">12 years building education programs</p>
          </a>
          <a href="/founder-story" class="block p-4 bg-white border border-slate-200 rounded-lg hover:border-blue-300 hover:shadow transition-all">
            <p class="font-semibold text-slate-900 mb-1">About Gautam</p>
            <p class="text-sm text-slate-600">Founder's journey and philosophy</p>
          </a>
          <a href="/blog" class="block p-4 bg-white border border-slate-200 rounded-lg hover:border-blue-300 hover:shadow transition-all">
            <p class="font-semibold text-slate-900 mb-1">Blog</p>
            <p class="text-sm text-slate-600">Insights and lessons learned</p>
          </a>
        </div>
      </div>

    </div>
  </Container>
</Layout>

            <div class="text-xs font-bold uppercase tracking-widest text-myna-amber/60">The Model</div>
            {[
              ["Funding", "₹999/mo or ₹4,999/6 months"],
              ["Delivery", "Self-serve + ABC credits"],
              ["Customer", "Individual students directly"],
              ["Scalability", "High — no gatekeepers"],
            ].map(([k, v]) => (

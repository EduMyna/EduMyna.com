---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
---

<Layout
  title="Quick Links"
  description="Reference page for all EduMyna content and resources"
>
  <Container>
    <div class="max-w-4xl mx-auto py-16 md:py-24">
      <h1 class="text-4xl font-bold text-slate-900 mb-3">Quick Links & Resources</h1>
      <p class="text-slate-600 mb-12">All EduMyna content and documents in one place.</p>

      <!-- Public Pages -->
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-slate-900 mb-4 pb-2 border-b border-slate-200">Public Pages</h2>
        <div class="space-y-3">
          <div>
            <a href="/story" class="text-lg font-semibold text-blue-600 hover:text-blue-700">/story</a>
            <p class="text-sm text-slate-600">Complete 12-year founder narrative (8 chapters + timeline)</p>
          </div>
          <div>
            <a href="/evolution" class="text-lg font-semibold text-blue-600 hover:text-blue-700">/evolution</a>
            <p class="text-sm text-slate-600">5 Acts of organizational transformation (2012-2024) with visual timeline & business model evolution</p>
          </div>
          <div>
            <a href="/master-timeline" class="text-lg font-semibold text-blue-600 hover:text-blue-700">/master-timeline</a>
            <p class="text-sm text-slate-600">Complete master narrative timeline (markdown source rendered as webpage)</p>
          </div>
          <div>
            <a href="/founder-story" class="text-lg font-semibold text-blue-600 hover:text-blue-700">/founder-story</a>
            <p class="text-sm text-slate-600">Comprehensive credibility page (About Gautam)</p>
          </div>
          <div>
            <a href="/pitch" class="text-lg font-semibold text-blue-600 hover:text-blue-700">/pitch</a>
            <p class="text-sm text-slate-600">Section 8 Investor Pitch Deck (web version, revenue-focused)</p>
          </div>
          <div>
            <a href="/team-deck" class="text-lg font-semibold text-blue-600 hover:text-blue-700">/team-deck</a>
            <p class="text-sm text-slate-600">Team & Partner Recruitment Deck (web version, mission-driven)</p>
          </div>
          <div>
            <a href="/blog/what-12-years-building-edtech-taught-me" class="text-lg font-semibold text-blue-600 hover:text-blue-700">/blog/what-12-years-building-edtech-taught-me</a>
            <p class="text-sm text-slate-600">10 lessons from 12 years of building education programs</p>
          </div>
        </div>
      </section>

      <!-- Strategy Documents -->
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-slate-900 mb-4 pb-2 border-b border-slate-200">Strategy Documents</h2>
        <div class="space-y-3">
          <div>
            <a href="https://github.com/EduMyna/EduMyna.com/blob/main/MASTER_NARRATIVE_TIMELINE.md" target="_blank" rel="noopener" class="text-lg font-semibold text-blue-600 hover:text-blue-700">MASTER_NARRATIVE_TIMELINE.md ↗</a>
            <p class="text-sm text-slate-600">Complete 2009-2024 timeline with all metrics, partnerships, photos catalog</p>
            <p class="text-xs text-slate-500 font-mono mt-1">github.com/EduMyna/EduMyna.com/blob/main/MASTER_NARRATIVE_TIMELINE.md</p>
          </div>
          <div>
            <a href="https://github.com/EduMyna/EduMyna.com/blob/main/PITCH_DECK_NARRATIVE_SECTION8.md" target="_blank" rel="noopener" class="text-lg font-semibold text-blue-600 hover:text-blue-700">PITCH_DECK_NARRATIVE_SECTION8.md ↗</a>
            <p class="text-sm text-slate-600">15-slide investor pitch (Section 8, revenue-focused, sustainable)</p>
            <p class="text-xs text-slate-500 font-mono mt-1">github.com/EduMyna/EduMyna.com/blob/main/PITCH_DECK_NARRATIVE_SECTION8.md</p>
          </div>
          <div>
            <a href="https://github.com/EduMyna/EduMyna.com/blob/main/FOUNDER_STORY_DECK.md" target="_blank" rel="noopener" class="text-lg font-semibold text-blue-600 hover:text-blue-700">FOUNDER_STORY_DECK.md ↗</a>
            <p class="text-sm text-slate-600">20-slide team/partner recruitment deck (mission-driven narrative)</p>
            <p class="text-xs text-slate-500 font-mono mt-1">github.com/EduMyna/EduMyna.com/blob/main/FOUNDER_STORY_DECK.md</p>
          </div>
        </div>
      </section>

      <!-- Content Files -->
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-slate-900 mb-4 pb-2 border-b border-slate-200">Content Files</h2>
        <div class="space-y-3">
          <div>
            <a href="https://github.com/EduMyna/EduMyna.com/blob/main/src/pages/story.astro" target="_blank" rel="noopener" class="text-lg font-semibold text-blue-600 hover:text-blue-700">story.astro ↗</a>
            <p class="text-sm text-slate-600">Evolution story page source (with real photos)</p>
            <p class="text-xs text-slate-500 font-mono mt-1">github.com/EduMyna/EduMyna.com/blob/main/src/pages/story.astro</p>
          </div>
          <div>
            <a href="https://github.com/EduMyna/EduMyna.com/blob/main/src/pages/founder-story.astro" target="_blank" rel="noopener" class="text-lg font-semibold text-blue-600 hover:text-blue-700">founder-story.astro ↗</a>
            <p class="text-sm text-slate-600">About Gautam credibility page source</p>
            <p class="text-xs text-slate-500 font-mono mt-1">github.com/EduMyna/EduMyna.com/blob/main/src/pages/founder-story.astro</p>
          </div>
          <div>
            <a href="https://github.com/EduMyna/EduMyna.com/blob/main/src/pages/pitch.astro" target="_blank" rel="noopener" class="text-lg font-semibold text-blue-600 hover:text-blue-700">pitch.astro ↗</a>
            <p class="text-sm text-slate-600">Section 8 pitch deck page source</p>
            <p class="text-xs text-slate-500 font-mono mt-1">github.com/EduMyna/EduMyna.com/blob/main/src/pages/pitch.astro</p>
          </div>
          <div>
            <a href="https://github.com/EduMyna/EduMyna.com/blob/main/src/pages/team-deck.astro" target="_blank" rel="noopener" class="text-lg font-semibold text-blue-600 hover:text-blue-700">team-deck.astro ↗</a>
            <p class="text-sm text-slate-600">Team recruitment deck page source</p>
            <p class="text-xs text-slate-500 font-mono mt-1">github.com/EduMyna/EduMyna.com/blob/main/src/pages/team-deck.astro</p>
          </div>
          <div>
            <a href="https://github.com/EduMyna/EduMyna.com/blob/main/src/content/blog/what-12-years-building-edtech-taught-me.md" target="_blank" rel="noopener" class="text-lg font-semibold text-blue-600 hover:text-blue-700">what-12-years-building-edtech-taught-me.md ↗</a>
            <p class="text-sm text-slate-600">Blog post source file</p>
            <p class="text-xs text-slate-500 font-mono mt-1">github.com/EduMyna/EduMyna.com/blob/main/src/content/blog/what-12-years-building-edtech-taught-me.md</p>
          </div>
        </div>
      </section>

      <!-- Press Mentions -->
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-slate-900 mb-4 pb-2 border-b border-slate-200">Media Archive</h2>
        <div class="bg-gradient-to-br from-blue-50 to-slate-50 border-2 border-blue-200 rounded-xl p-6">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-blue-600 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
              </svg>
            </div>
            <div class="flex-1">
              <a href="/press-mentions" class="text-xl font-bold text-slate-900 hover:text-blue-600 transition-colors">Press Mentions & Media Coverage →</a>
              <p class="text-sm text-slate-700 mt-2 mb-3">
                Comprehensive archive of 30+ media stories documenting the 12-year journey from Startup Village (2009) to SV.CO, Pupilfirst, and beyond.
              </p>
              <div class="flex flex-wrap gap-2">
                <span class="px-2 py-1 bg-white text-blue-700 text-xs font-medium rounded border border-blue-200">BBC Coverage</span>
                <span class="px-2 py-1 bg-white text-blue-700 text-xs font-medium rounded border border-blue-200">#1 Incubator</span>
                <span class="px-2 py-1 bg-white text-blue-700 text-xs font-medium rounded border border-blue-200">Times of India</span>
                <span class="px-2 py-1 bg-white text-blue-700 text-xs font-medium rounded border border-blue-200">Economic Times</span>
                <span class="px-2 py-1 bg-white text-blue-700 text-xs font-medium rounded border border-blue-200">SV.CO Blog</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Images -->
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-slate-900 mb-4 pb-2 border-b border-slate-200">Story Images</h2>
        <p class="text-sm text-slate-600 mb-4">All images copied to: <code class="text-xs bg-slate-100 px-2 py-1 rounded">/public/images/story/</code></p>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <img src="/images/story/sv-collage.jpg" alt="SV Collage" class="w-full aspect-video object-cover rounded border border-slate-200 mb-2" />
            <p class="text-xs text-slate-600">sv-collage.jpg</p>
          </div>
          <div>
            <img src="/images/story/sv-team.jpg" alt="SV Team" class="w-full aspect-video object-cover rounded border border-slate-200 mb-2" />
            <p class="text-xs text-slate-600">sv-team.jpg</p>
          </div>
          <div>
            <img src="/images/story/google-mountainview.jpg" alt="Google Mountain View" class="w-full aspect-video object-cover rounded border border-slate-200 mb-2" />
            <p class="text-xs text-slate-600">google-mountainview.jpg</p>
          </div>
          <div>
            <img src="/images/story/facebook-hq.jpg" alt="Facebook HQ" class="w-full aspect-video object-cover rounded border border-slate-200 mb-2" />
            <p class="text-xs text-slate-600">facebook-hq.jpg</p>
          </div>
          <div>
            <img src="/images/story/college-scenes.jpg" alt="College Scenes" class="w-full aspect-video object-cover rounded border border-slate-200 mb-2" />
            <p class="text-xs text-slate-600">college-scenes.jpg</p>
          </div>
          <div>
            <img src="/images/story/gopi-kallayil.jpg" alt="Gopi Kallayil" class="w-full aspect-video object-cover rounded border border-slate-200 mb-2" />
            <p class="text-xs text-slate-600">gopi-kallayil.jpg</p>
          </div>
        </div>
      </section>

      <!-- Quick Summary -->
      <section class="bg-slate-50 border border-slate-200 rounded-xl p-6">
        <h2 class="text-xl font-bold text-slate-900 mb-3">Content Summary - Three Narrative Versions</h2>

        <div class="mb-6 p-4 bg-blue-50 border border-blue-200 rounded-lg">
          <p class="text-sm font-semibold text-blue-900 mb-2">📖 Review These Three for Narrative Alignment:</p>
          <ul class="space-y-2 text-sm text-blue-800">
            <li class="flex items-start gap-2">
              <span class="text-blue-600 mt-0.5">1.</span>
              <span><strong>/story</strong> - Original 12-year founder narrative (8 chapters, written before evolution framework)</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-blue-600 mt-0.5">2.</span>
              <span><strong>/evolution</strong> - New 5 Acts framework with visual timeline and business model evolution</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-blue-600 mt-0.5">3.</span>
              <span><strong>/master-timeline</strong> - Complete markdown source (updated with evolution narrative)</span>
            </li>
          </ul>
        </div>

        <h3 class="text-lg font-bold text-slate-900 mb-3 mt-6">All Content Pages</h3>
        <ul class="space-y-2 text-sm text-slate-700">
          <li class="flex items-start gap-2">
            <span class="text-blue-600 mt-0.5">✓</span>
            <span><strong>Master Timeline:</strong> /master-timeline - Complete source of truth (2009-2024) rendered as webpage</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-blue-600 mt-0.5">✓</span>
            <span><strong>Evolution Story:</strong> /evolution - 5 Acts framework with interactive timeline</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-blue-600 mt-0.5">✓</span>
            <span><strong>Story Page:</strong> /story - 12-year narrative with real photos (original version)</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-blue-600 mt-0.5">✓</span>
            <span><strong>Section 8 Pitch (Web):</strong> /pitch - Investor deck (₹2-5Cr ask, revenue-focused)</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-blue-600 mt-0.5">✓</span>
            <span><strong>Team Deck (Web):</strong> /team-deck - Partner recruitment (mission-driven)</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-blue-600 mt-0.5">✓</span>
            <span><strong>Credibility Page:</strong> /founder-story - All ventures, partnerships, philosophy</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-blue-600 mt-0.5">✓</span>
            <span><strong>Blog Post:</strong> 10 lessons from 12 years building EdTech</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-blue-600 mt-0.5">✓</span>
            <span><strong>Press Mentions:</strong> /press-mentions - 30+ media stories (BBC, ET, TOI, 2013-2019)</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-blue-600 mt-0.5">✓</span>
            <span><strong>Markdown Versions:</strong> PITCH_DECK_NARRATIVE_SECTION8.md + FOUNDER_STORY_DECK.md + MASTER_NARRATIVE_TIMELINE.md</span>
          </li>
        </ul>
      </section>

      <div class="mt-12 text-center text-sm text-slate-500">
        <p>This page is unlisted and not linked anywhere on the site.</p>
        <p>Direct access only: <code class="bg-slate-100 px-2 py-1 rounded">edumyna.com/links</code></p>
      </div>
    </div>
  </Container>
</Layout>
